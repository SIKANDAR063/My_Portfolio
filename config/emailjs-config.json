{
  "META": {
    "app": "portfolio-sikandar",
    "module": "emailjs",
    "version": "1.0.0",
    "environment": "production",
    "description": "Central configuration for EmailJS contact form integration"
  },

  "EMAILJS": {
    "PUBLIC_KEY": "m8qt6xU5vaNTBdHZ5",
    "SERVICE_ID": "service_2rvnc07",
    "TEMPLATE_ID": "template_a9zr09n",
    "TO_EMAIL": "sikandarali3572@gmail.com"
  },

  "FORM": {
    "FIELDS": ["name", "email", "subject", "message"],
    "SANITIZE_INPUT": true,
    "TRIM_WHITESPACE": true
  },

  "VALIDATION": {
    "name": {
      "required": true,
      "minLength": 2,
      "maxLength": 100,
      "pattern": "^[a-zA-Z\\s\\-']+$",
      "label": "Name"
    },
    "email": {
      "required": true,
      "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$",
      "label": "Email Address"
    },
    "subject": {
      "required": true,
      "minLength": 5,
      "maxLength": 200,
      "label": "Subject"
    },
    "message": {
      "required": true,
      "minLength": 10,
      "maxLength": 2000,
      "label": "Message"
    }
  },

  "MESSAGES": {
    "STATUS": {
      "sending": "📤 Sending your message...",
      "success": "✅ Message sent successfully! I'll get back to you soon.",
      "error": "❌ Failed to send message. Please try again or email me directly."
    },
    "VALIDATION": {
      "required": "This field is required",
      "email": "Please enter a valid email address",
      "minLength": "Must be at least {min} characters",
      "maxLength": "Cannot exceed {max} characters",
      "pattern": "Please enter a valid value"
    }
  },

  "FALLBACK": {
    "enabled": true,
    "storage": {
      "key": "contactFormBackup",
      "format": "json",
      "encrypt": false
    },
    "retry": {
      "enabled": true,
      "intervalMs": 30000,
      "maxRetries": 3
    },
    "notification": {
      "console": true,
      "userMessage": "⚠️ Your message was saved locally and will be retried automatically."
    }
  },

  "SECURITY": {
    "rateLimit": {
      "enabled": true,
      "maxSubmissions": 3,
      "perMinutes": 5
    },
    "honeypot": {
      "enabled": true,
      "fieldName": "company"
    }
  },

  "DEBUG": {
    "logRequests": false,
    "logResponses": false
  }
}
